{
  "name": "@vectotaxsoftwaregmbh/n8n-nodes-taxmetall",
  "version": "1.23.0",
  "description": "n8n community node for TaxMetall ERP — read customers, articles, orders, offers, invoices, delivery notes, purchase invoices, suppliers, dunning, and execute statistics queries via the TaxMetall REST API.",
  "license": "MIT",
  "homepage": "https://www.vectotax.de",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vectotax/n8n-nodes-taxmetall.git"
  },
  "bugs": {
    "url": "mailto:vectotax@vectotax.de"
  },
  "keywords": [
    "n8n-community-node-package",
    "taxmetall",
    "erp",
    "vectotax"
  ],
  "author": {
    "name": "Vectotax Software GmbH",
    "email": "vectotax@vectotax.de"
  },
  "scripts": {
    "build": "n8n-node build && node scripts/copy-locals.js",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/TaxMetallApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TaxMetall/TaxMetall.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "0.23.0",
    "n8n-workflow": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "release-it": {
    "npm": {
      "publish": false
    }
  }
}
